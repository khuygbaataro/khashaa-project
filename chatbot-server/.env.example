# Anthropic
ANTHROPIC_API_KEY=
# Optional override. Default: claude-haiku-4-5 (fast, cheap, good enough for chat)
# Set to claude-opus-4-7 for higher-quality answers but more cost
ANTHROPIC_MODEL=claude-haiku-4-5

# Facebook Messenger
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_APP_SECRET=
FACEBOOK_VERIFY_TOKEN=khashaa-verify-pick-anything

# Firebase (server-side admin SDK)
# Either base64 the contents of the service-account JSON and put it here…
FIREBASE_SERVICE_ACCOUNT=
# …or set GOOGLE_APPLICATION_CREDENTIALS to a path. On Cloud Run with default
# service account neither is needed — admin SDK auto-detects.

# Optional
PORT=8080
PUBLIC_SITE_URL=https://claude.mn
