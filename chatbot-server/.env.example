# DO NOT put real secrets in this file. This is the template that gets committed
# to git. Copy this to .env (which is gitignored) and put the real values there.

# Anthropic
ANTHROPIC_API_KEY=
# Default: claude-opus-4-7 (highest quality for the Zaisan customer bot).
# Switch to claude-haiku-4-5-20251001 only if you need to optimize cost.
ANTHROPIC_MODEL=claude-opus-4-7

# Facebook Messenger
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_APP_SECRET=
FACEBOOK_VERIFY_TOKEN=khashaa-verify-pick-anything

# Firebase (server-side admin SDK)
# Either paste the raw service-account JSON on a single line, or base64-encode it.
# Both work. On Cloud Run with default service account, leave this blank.
FIREBASE_SERVICE_ACCOUNT=

# Optional
PORT=8080
PUBLIC_SITE_URL=https://claude.mn
